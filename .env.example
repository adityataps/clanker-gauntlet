# Copy this to .env and fill in values for local development

# Database (docker-compose default)
DATABASE_URL=postgresql+asyncpg://clanker:clanker@localhost:5432/clanker_gauntlet

# Redis (docker-compose default)
REDIS_URL=redis://localhost:6379

# Auth — set to "auth0" or "jwt"
AUTH_PROVIDER=jwt

# Auth0 (required if AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# JWT (required if AUTH_PROVIDER=jwt)
JWT_SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Encryption key for user Anthropic API keys at rest (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Anthropic platform-level key (fallback if user has no key set)
ANTHROPIC_API_KEY=
